# ──────────────────────────────────────────────────────────────────────────────
# Scuderia F1 Simulator — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit the real .env file — it is gitignored.
# ──────────────────────────────────────────────────────────────────────────────

# CORS: comma-separated list of allowed frontend origins.
# Defaults to http://localhost:3000,http://localhost:5173 if not set.
# For production, set this to your deployed frontend URL.
# Example: ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
