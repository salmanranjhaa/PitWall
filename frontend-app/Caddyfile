# PitWall internal Caddy — serves the SPA and proxies /api to the backend.
# TLS is terminated upstream by the VM's shared Caddy (infra-frontend).
:80 {
    handle /api/* {
        # flush_interval -1 keeps the /api/race/stream SSE flowing lap by lap
        reverse_proxy pitwall-backend:8000 {
            flush_interval -1
        }
    }

    handle {
        root * /usr/share/caddy
        try_files {path} /index.html

        @immutable path /assets/*
        header @immutable Cache-Control "public, max-age=31536000, immutable"
        @no_cache path / /index.html
        header @no_cache Cache-Control "no-cache, must-revalidate"

        file_server
    }
}
